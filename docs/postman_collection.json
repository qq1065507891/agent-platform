{
  "info": {
    "name": "Agent Platform MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8000/api/v1"},
    {"key": "token", "value": ""},
    {"key": "agent_id", "value": ""},
    {"key": "conversation_id", "value": ""},
    {"key": "user_id", "value": ""}
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Passw0rd!\",\n  \"login_type\": \"password\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.access_token) {",
              "  pm.collectionVariables.set('token', json.data.access_token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "{{baseUrl}}/users?page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["users"], "query": [{"key": "page", "value": "1"}, {"key": "page_size", "value": "20"}]}
      }
    },
    {
      "name": "Users - Create",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Passw0rd!\",\n  \"role\": \"user\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('user_id', json.data.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/users/{{user_id}}", "host": ["{{baseUrl}}"], "path": ["users", "{{user_id}}"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"manager\",\n  \"status\": \"active\"\n}"
        }
      }
    },
    {
      "name": "Users - Import",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/users/import", "host": ["{{baseUrl}}"], "path": ["users", "import"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"users\": [\n    {\"username\": \"d1\", \"email\": \"d1@example.com\", \"password\": \"Passw0rd!\", \"role\": \"user\"},\n    {\"username\": \"d2\", \"email\": \"d2@example.com\", \"password\": \"Passw0rd!\", \"role\": \"user\"}\n  ]\n}"
        }
      }
    },
    {
      "name": "Agents - Create",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/agents", "host": ["{{baseUrl}}"], "path": ["agents"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"日报助手\",\n  \"description\": \"生成日报\",\n  \"prompt_template\": \"你是一个日报助手...\",\n  \"skills\": [{\"skill_id\": \"text_summary\"}],\n  \"is_public\": true\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('agent_id', json.data.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Agents - List",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "{{baseUrl}}/agents?page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["agents"], "query": [{"key": "page", "value": "1"}, {"key": "page_size", "value": "20"}]}
      }
    },
    {
      "name": "Agents - Detail",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "{{baseUrl}}/agents/{{agent_id}}", "host": ["{{baseUrl}}"], "path": ["agents", "{{agent_id}}"]}
      }
    },
    {
      "name": "Agents - Update",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/agents/{{agent_id}}", "host": ["{{baseUrl}}"], "path": ["agents", "{{agent_id}}"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"生成标准化日报\",\n  \"is_public\": false\n}"
        }
      }
    },
    {
      "name": "Conversations - Create",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/conversations", "host": ["{{baseUrl}}"], "path": ["conversations"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"{{agent_id}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('conversation_id', json.data.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Conversations - Detail",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
        "url": {"raw": "{{baseUrl}}/conversations/{{conversation_id}}", "host": ["{{baseUrl}}"], "path": ["conversations", "{{conversation_id}}"]}
      }
    },
    {
      "name": "Conversations - Send Message",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "{{baseUrl}}/conversations/{{conversation_id}}/messages", "host": ["{{baseUrl}}"], "path": ["conversations", "{{conversation_id}}", "messages"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"今天完成了接口联调\",\n  \"attachments\": []\n}"
        }
      }
    }
  ]
}