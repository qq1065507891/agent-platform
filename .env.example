# =========================
# Application
# =========================
APP_ENV=prod
APP_NAME=agent_platform
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_DB=agent_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=change_this_password
DB_URL=postgresql+psycopg2://agent:change_this_password@postgres:5432/agent_platform

# =========================
# Redis / Celery
# =========================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =========================
# LLM Required
# =========================
LLM_GATEWAY_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional: fast chat lane
LLM_CHAT_FAST_BASE_URL=
LLM_CHAT_FAST_API_KEY=
LLM_CHAT_FAST_MODEL=

# Optional: embeddings lane
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIMENSIONS=1024

# Optional: memory extraction lane
MEMORY_EXTRACTION_BASE_URL=
MEMORY_EXTRACTION_API_KEY=
MEMORY_EXTRACTION_MODEL=
MEMORY_EXTRACTION_TIMEOUT_SECONDS=20

# Optional: router/worker lane
ROUTER_LLM_BASE_URL=
ROUTER_LLM_API_KEY=
ROUTER_LLM_MODEL=
ROUTER_LLM_TIMEOUT_SECONDS=4
ROUTER_WORKER_BASE_URL=
ROUTER_WORKER_API_KEY=
ROUTER_WORKER_MODEL=
ROUTER_WORKER_TIMEOUT_SECONDS=4
ROUTER_WORKER_MAX_WORKERS=2

# =========================
# Chroma (local persistent volume in container)
# =========================
CHROMA_PERSIST_PATH=/app/chroma

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=http://backend:8000

# =========================
# Optional TLS Gateway (Caddy profile)
# =========================
GATEWAY_DOMAIN=example.com
GATEWAY_TLS_EMAIL=ops@example.com
